{
  "name": "foosball-api",
  "version": "0.1.0",
  "description": "Foosball tracking API — NestJS monorepo (api, auth, worker, producer)",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build api && nest build auth && nest build worker && nest build producer",
    "build:api": "nest build api",
    "build:auth": "nest build auth",
    "build:worker": "nest build worker",
    "build:producer": "nest build producer",
    "format": "prettier --write \"{apps,libs,test}/**/*.ts\"",
    "start": "concurrently \"npm run start:api\" \"npm run start:auth\" \"npm run start:worker\" \"npm run start:producer\"",
    "start:dev": "nest start api --watch",
    "start:debug": "nest start api --debug --watch",
    "start:api": "nest start api --watch",
    "start:auth": "nest start auth --watch",
    "start:worker": "nest start worker --watch",
    "start:producer": "nest start producer --watch",
    "start:prod:api": "node dist/apps/api/main",
    "start:prod:auth": "node dist/apps/auth/main",
    "start:prod:worker": "node dist/apps/worker/main",
    "start:prod:producer": "node dist/apps/producer/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "npx typeorm migration:generate -d dist/libs/database/src/data-source.js",
    "migration:run": "npx typeorm migration:run -d dist/libs/database/src/data-source.js",
    "migration:revert": "npx typeorm migration:revert -d dist/libs/database/src/data-source.js"
  },
  "dependencies": {
    "@azure/msal-node": "2.16.3",
    "@fastify/cors": "11.2.0",
    "@fastify/static": "^9.1.3",
    "@microsoft/microsoft-graph-client": "3.0.7",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-fastify": "11.1.21",
    "@nestjs/schedule": "5.0.1",
    "@nestjs/swagger": "11.4.3",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "11.0.1",
    "bullmq": "5.76.8",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.4",
    "concurrently": "^9.2.1",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "mysql2": "3.22.3",
    "passport": "0.7.0",
    "passport-azure-ad": "4.3.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "0.3.29"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "^24.0.0",
    "@types/passport": "1.0.17",
    "@types/passport-azure-ad": "^4.0.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "ioredis-mock": "8.13.1",
    "jest": "^30.0.0",
    "jest-mock-extended": "4.0.1",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "roots": [
      "<rootDir>/apps",
      "<rootDir>/libs"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "apps/**/*.ts",
      "libs/**/*.ts",
      "!**/*.module.ts",
      "!**/main.ts",
      "!**/index.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.{1,2}/.+)\\.js$": "$1",
      "@app/common/(.+)\\.js$": "<rootDir>/libs/common/src/$1",
      "@app/common/(.*)": "<rootDir>/libs/common/src/$1",
      "@app/common": "<rootDir>/libs/common/src/index.ts",
      "@app/database/(.+)\\.js$": "<rootDir>/libs/database/src/$1",
      "@app/database/(.*)": "<rootDir>/libs/database/src/$1",
      "@app/database": "<rootDir>/libs/database/src/index.ts",
      "@app/events/(.+)\\.js$": "<rootDir>/libs/events/src/$1",
      "@app/events/(.*)": "<rootDir>/libs/events/src/$1",
      "@app/events": "<rootDir>/libs/events/src/index.ts",
      "@app/matches/(.+)\\.js$": "<rootDir>/libs/matches/src/$1",
      "@app/matches/(.*)": "<rootDir>/libs/matches/src/$1",
      "@app/matches": "<rootDir>/libs/matches/src/index.ts",
      "@app/leaderboard/(.+)\\.js$": "<rootDir>/libs/leaderboard/src/$1",
      "@app/leaderboard/(.*)": "<rootDir>/libs/leaderboard/src/$1",
      "@app/leaderboard": "<rootDir>/libs/leaderboard/src/index.ts",
      "@app/auth/(.+)\\.js$": "<rootDir>/libs/auth/src/$1",
      "@app/auth/(.*)": "<rootDir>/libs/auth/src/$1",
      "@app/auth": "<rootDir>/libs/auth/src/index.ts",
      "@app/users/(.+)\\.js$": "<rootDir>/libs/users/src/$1",
      "@app/users/(.*)": "<rootDir>/libs/users/src/$1",
      "@app/users": "<rootDir>/libs/users/src/index.ts",
      "@app/jobs/(.+)\\.js$": "<rootDir>/libs/jobs/src/$1",
      "@app/jobs/(.*)": "<rootDir>/libs/jobs/src/$1",
      "@app/jobs": "<rootDir>/libs/jobs/src/index.ts"
    }
  }
}
