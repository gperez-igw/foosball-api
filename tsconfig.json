{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@app/common": ["libs/common/src/index"],
      "@app/common/*": ["libs/common/src/*"],
      "@app/database": ["libs/database/src/index"],
      "@app/database/*": ["libs/database/src/*"],
      "@app/events": ["libs/events/src/index"],
      "@app/events/*": ["libs/events/src/*"],
      "@app/matches": ["libs/matches/src/index"],
      "@app/matches/*": ["libs/matches/src/*"],
      "@app/leaderboard": ["libs/leaderboard/src/index"],
      "@app/leaderboard/*": ["libs/leaderboard/src/*"],
      "@app/auth": ["libs/auth/src/index"],
      "@app/auth/*": ["libs/auth/src/*"],
      "@app/users": ["libs/users/src/index"],
      "@app/users/*": ["libs/users/src/*"],
      "@app/jobs": ["libs/jobs/src/index"],
      "@app/jobs/*": ["libs/jobs/src/*"]
    }
  }
}
