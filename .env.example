# ─── General ────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ─── App ports ──────────────────────────────────────────────────────────────────
# apps/api HTTP server
API_PORT=3000
# apps/auth HTTP server
AUTH_PORT=3001

# ─── Database (MySQL 8) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=foosball
DB_PASSWORD=foosball
DB_NAME=foosball
# Only needed for docker-compose service initialization
DB_ROOT_PASSWORD=rootpassword

# ─── Redis 7 ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave empty for no-auth local Redis (docker-compose default)
REDIS_PASSWORD=

# ─── JWT ────────────────────────────────────────────────────────────────────────
# REQUIRED — minimum 32 chars, random string. NEVER commit a real value.
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=24h

# ─── Azure AD / MSAL ────────────────────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
# Must match a Reply URL configured in Azure App Registration
AZURE_REDIRECT_URI=http://localhost:3001/auth/callback
# Azure AD Group ObjectId whose members receive is_admin=true
ADMIN_AZURE_GROUP_ID=your-admin-group-object-id

# ─── CORS (comma-separated allowed origins, empty = API-only / no browser) ─────
CORS_ORIGINS=
